generator client {
  provider = "prisma-client-js"
  
  binaryTargets = ["native", "windows"]
  
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") 
   
}

enum Role {
  SUPER_ADMIN
  ADMIN
  COORDINATOR
  RLDC_ADMIN
  RLDC_COORDINATOR
  RLDC_USER
  RLDC_ANALYST
  USER
}
model User {
  id                String                 @id @default(uuid())
  userType          String
  username          String                 @unique
  password          String
  createdAt         DateTime               @default(now())
  profile           AccountManagerProfile?
  approvals         Approval[]
  associateManagers AssociateManager[]
  entity            Entity?
  meters            Meter[]
  qcaDetails        QCADetails?
  role              RoleAssignment?
  tokens            UserToken[]
  
  
}

model UserToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model AccountManagerProfile {
  id          String  @id @default(uuid())
  userId      String  @unique
  fullName    String
  designation String
  email       String  @unique
  altEmail    String?
  phone       String
  altPhone    String?
  user        User    @relation(fields: [userId], references: [id])
}

model Entity {
  id         String @id @default(uuid())
  userId     String @unique
  entityName String
  substation String
  ownerName  String @default("GRID India")
  ownerEmail String
  ownerPhone String
  rldc       String @default("")
  user       User   @relation(fields: [userId], references: [id])
}

model AssociateManager {
  id          String  @id @default(uuid())
  userId      String
  name        String?
  designation String?
  email       String?
  phone       String?
  user        User    @relation(fields: [userId], references: [id])
}

model Meter {
  id         String @id @default(uuid())
  userId     String
  meterNo    String
  meterOwner String
  user       User   @relation(fields: [userId], references: [id])

  @@unique([meterNo, userId])
}

model QCADetails {
  id              String  @id @default(uuid())
  userId          String  @unique
  licenseNumber   String
  managedStations String?
  user            User    @relation(fields: [userId], references: [id])
}

model RoleAssignment {
  id         String @id @default(uuid())
  userId     String @unique
  role       Role
  approverId String?
  user       User   @relation(fields: [userId], references: [id])
}

model Approval {
  id         String   @id @default(uuid())
  userId     String
  approverId String?
  status     String   @default("Pending")
  // Possible values:
  // "Pending"             → just registered, waiting for coordinator
  // "CoordinatorApproved" → coordinator approved, waiting for admin
  // "CoordinatorRejected" → coordinator rejected
  // "AdminApproved"       → admin approved, waiting for activation
  // "AdminRejected"       → admin rejected
  // "Activated"           → fully active
  remarks    String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}
