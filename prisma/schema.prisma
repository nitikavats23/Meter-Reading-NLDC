generator client {
  provider = "prisma-client-js"
  
  binaryTargets = ["native", "windows"]
  
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") 
   
}

model User {
  id                String                 @id @default(uuid())
  userType          String
  username          String                 @unique
  password          String
  createdAt         DateTime               @default(now())
  profile           AccountManagerProfile?
  approvals         Approval[]
  associateManagers AssociateManager[]
  entity            Entity?
  meters            Meter[]
  qcaDetails        QCADetails?
  role              RoleAssignment?
}

model AccountManagerProfile {
  id          String  @id @default(uuid())
  userId      String  @unique
  fullName    String
  designation String
  email       String  @unique
  altEmail    String?
  phone       String
  altPhone    String?
  user        User    @relation(fields: [userId], references: [id])
}

model Entity {
  id         String @id @default(uuid())
  userId     String @unique
  entityName String
  substation String
  ownerName  String
  ownerEmail String
  ownerPhone String
  user       User   @relation(fields: [userId], references: [id])
}

model AssociateManager {
  id          String  @id @default(uuid())
  userId      String
  name        String?
  designation String?
  email       String?
  phone       String?
  user        User    @relation(fields: [userId], references: [id])
}

model Meter {
  id         String @id @default(uuid())
  userId     String
  meterNo    String
  meterOwner String
  user       User   @relation(fields: [userId], references: [id])

  @@unique([meterNo, userId])
}

model QCADetails {
  id              String  @id @default(uuid())
  userId          String  @unique
  licenseNumber   String
  managedStations String?
  user            User    @relation(fields: [userId], references: [id])
}

model RoleAssignment {
  id         String @id @default(uuid())
  userId     String @unique
  role       String
  approverId String
  user       User   @relation(fields: [userId], references: [id])
}

model Approval {
  id         String   @id @default(uuid())
  userId     String
  approverId String
  status     String
  remarks    String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}
